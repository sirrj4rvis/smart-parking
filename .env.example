# Copy to .env and adjust. Never commit real secrets.

# Core
FLASK_ENV=development               # development | testing | production
SECRET_KEY=generate-a-long-random-string-min-32-chars
JWT_SECRET_KEY=another-long-random-string

# Database (omit to use local SQLite)
# DATABASE_URL=postgresql+psycopg://smartpark:smartpark@localhost:5432/smartpark

# Redis (cache, rate-limit, socket.io queue, celery) — omit for in-memory dev
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
SESSION_COOKIE_SECURE=0             # set 1 behind HTTPS
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Pricing
PRICING_SURGE_ENABLED=1
PRICING_SURGE_MAX=2.0
PRICING_SURGE_THRESHOLD=0.6
RESERVATION_TTL_MINUTES=10

# Payments (Razorpay) — TEST keys are free; omit to use the local mock provider
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxx
# RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxx

# UPI direct payment (free, no gateway) — set to YOUR UPI ID to receive payments.
# Scanning the receipt QR in any UPI app then shows the real amount + payee.
# UPI_VPA=yourname@okhdfcbank
# UPI_PAYEE_NAME=SmartPark ITS

# Observability
# SENTRY_DSN=
LOG_LEVEL=INFO
LOG_JSON=1
METRICS_ENABLED=1
